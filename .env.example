# =============================================================================
# ATHENA (XYLEX GROUP) - PRODUCTION DB + AUTH GATEWAY
# =============================================================================
ATHENA_URL=https://mirror3.athena-db.com
NEXT_PUBLIC_ATHENA_URL=https://mirror3.athena-db.com
ATHENA_API_KEY=your-athena-gateway-api-key
NEXT_PUBLIC_ATHENA_API_KEY=your-athena-gateway-api-key
ATHENA_ADMIN_API_KEY=your-athena-admin-api-key
ATHENA_DATABASE=ikiform
ATHENA_CLIENT=ikiform

# =============================================================================
# Athena Auth server (separate from gateway for sessions, OAuth, password flows)
# =============================================================================
ATHENA_AUTH_URL=https://your-auth.athena.example.com/api/auth
NEXT_PUBLIC_ATHENA_AUTH_URL=https://your-auth.athena.example.com/api/auth
AUTH_BEARER_TOKEN=optional-bearer-token
# Optional legacy alias, kept for compatibility while rolling environment templates:
ATHENA_AUTH_BASE_URL=https://your-auth.athena.example.com/api/auth
NEXT_PUBLIC_ATHENA_AUTH_BASE_URL=https://your-auth.athena.example.com/api/auth
# Optional bearer if your Athena Auth instance requires it for certain endpoints
# AUTH_BEARER_TOKEN=

# =============================================================================
# VERCEL BLOB STORAGE (replaces Supabase Storage form-files bucket)
# =============================================================================
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# =============================================================================
# EMAIL SERVICE
# =============================================================================
RESEND_API_KEY=your-resend-api-key

# =============================================================================
# APPLICATION URLS
# =============================================================================
NEXT_PUBLIC_BASE_URL=http://localhost:3000
SITE_URL=http://localhost:3000

# =============================================================================
# PAYMENT INTEGRATION (POLAR)
# =============================================================================
POLAR_ACCESS_TOKEN=your-polar-access-token
POLAR_SUCCESS_URL=http://localhost:3000/success
POLAR_WEBHOOK_SECRET=your-polar-webhook-secret

# =============================================================================
# AI SERVICES
# =============================================================================
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=fastest
COHERE_API_KEY=your-cohere-api-key
ANALYTICS_AI_SYSTEM_PROMPT=your-analytics-ai-system-prompt
AI_FORM_SYSTEM_PROMPT=your-ai-form-system-prompt

# =============================================================================
# UPSTASH
# =============================================================================

UPSTASH_REDIS_REST_URL=your-upstash-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# =============================================================================
# VERCEL
# =============================================================================

CRON_SECRET=
